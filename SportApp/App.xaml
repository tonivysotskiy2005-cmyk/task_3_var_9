<Application x:Class="SportApp.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:SportApp.Converters"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>

            <!-- Converters -->
            <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
            <conv:BoolToVisibilityConverter x:Key="BoolToVisInv" Invert="True" />
            <conv:StringToBrushConverter x:Key="StringToBrush" />
            <conv:PercentToWidthConverter x:Key="PercentToWidth" />

            <!-- Palette -->
            <Color x:Key="BgColor">#0E1116</Color>
            <Color x:Key="BgElevatedColor">#171B22</Color>
            <Color x:Key="BgElevated2Color">#1F242D</Color>
            <Color x:Key="StrokeColor">#262C36</Color>
            <Color x:Key="StrokeSoftColor">#1D222B</Color>
            <Color x:Key="TextColor">#E6EAF2</Color>
            <Color x:Key="TextMutedColor">#8A93A6</Color>
            <Color x:Key="TextDimColor">#5C6576</Color>
            <Color x:Key="AccentColor">#D1FF3D</Color>
            <Color x:Key="AccentDeepColor">#9BD400</Color>
            <Color x:Key="WarnColor">#FFB547</Color>
            <Color x:Key="DangerColor">#FF4D5E</Color>
            <Color x:Key="InfoColor">#5CC8FF</Color>

            <SolidColorBrush x:Key="Bg" Color="{StaticResource BgColor}" />
            <SolidColorBrush x:Key="BgElevated" Color="{StaticResource BgElevatedColor}" />
            <SolidColorBrush x:Key="BgElevated2" Color="{StaticResource BgElevated2Color}" />
            <SolidColorBrush x:Key="Stroke" Color="{StaticResource StrokeColor}" />
            <SolidColorBrush x:Key="StrokeSoft" Color="{StaticResource StrokeSoftColor}" />
            <SolidColorBrush x:Key="Text" Color="{StaticResource TextColor}" />
            <SolidColorBrush x:Key="TextMuted" Color="{StaticResource TextMutedColor}" />
            <SolidColorBrush x:Key="TextDim" Color="{StaticResource TextDimColor}" />
            <SolidColorBrush x:Key="Accent" Color="{StaticResource AccentColor}" />
            <SolidColorBrush x:Key="AccentDeep" Color="{StaticResource AccentDeepColor}" />
            <SolidColorBrush x:Key="Warn" Color="{StaticResource WarnColor}" />
            <SolidColorBrush x:Key="Danger" Color="{StaticResource DangerColor}" />
            <SolidColorBrush x:Key="Info" Color="{StaticResource InfoColor}" />

            <!-- Typography -->
            <FontFamily x:Key="UiFont">Segoe UI</FontFamily>
            <FontFamily x:Key="MonoFont">Consolas</FontFamily>

            <Style TargetType="TextBlock" x:Key="H1">
                <Setter Property="FontFamily" Value="{StaticResource UiFont}" />
                <Setter Property="FontSize" Value="22" />
                <Setter Property="FontWeight" Value="Bold" />
                <Setter Property="Foreground" Value="{StaticResource Text}" />
            </Style>
            <Style TargetType="TextBlock" x:Key="H2">
                <Setter Property="FontFamily" Value="{StaticResource UiFont}" />
                <Setter Property="FontSize" Value="16" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{StaticResource Text}" />
            </Style>
            <Style TargetType="TextBlock" x:Key="Label">
                <Setter Property="FontFamily" Value="{StaticResource UiFont}" />
                <Setter Property="FontSize" Value="10" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
                <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
            </Style>
            <Style TargetType="TextBlock" x:Key="Stat">
                <Setter Property="FontFamily" Value="{StaticResource UiFont}" />
                <Setter Property="FontSize" Value="18" />
                <Setter Property="FontWeight" Value="Bold" />
                <Setter Property="Foreground" Value="{StaticResource Text}" />
            </Style>
            <Style TargetType="TextBlock" x:Key="Mono">
                <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
                <Setter Property="FontSize" Value="11" />
                <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
            </Style>

            <!-- Base text block style -->
            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource Text}" />
                <Setter Property="FontFamily" Value="{StaticResource UiFont}" />
            </Style>

            <!-- Button: primary -->
            <Style x:Key="PrimaryButton" TargetType="Button">
                <Setter Property="Background" Value="#3B82F6" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="FontWeight" Value="Bold" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="Padding" Value="14,8" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <ControlTemplate.Resources>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                    <Setter Property="FontWeight" Value="Bold" />
                                </Style>
                            </ControlTemplate.Resources>
                            <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="b" Property="Background" Value="#2563EB" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="b" Property="Background" Value="#2A2F3A" />
                                    <Setter Property="Foreground" Value="#5C6576" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Button: ghost/secondary -->
            <Style x:Key="GhostButton" TargetType="Button">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{StaticResource Text}" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="Padding" Value="12,7" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="BorderBrush" Value="{StaticResource Stroke}" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="b" Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="b" Property="Background" Value="#1F242D" />
                                    <Setter TargetName="b" Property="BorderBrush" Value="#3A424F" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Foreground" Value="#5C6576" />
                                    <Setter TargetName="b" Property="BorderBrush" Value="#22272F" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Button: danger ghost -->
            <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
                <Setter Property="Foreground" Value="{StaticResource Danger}" />
            </Style>

            <!-- Card surface -->
            <Style x:Key="Card" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource BgElevated}" />
                <Setter Property="BorderBrush" Value="{StaticResource Stroke}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="Padding" Value="16" />
                <Setter Property="Margin" Value="0,0,0,12" />
            </Style>

            <!-- ScrollBar -->
            <Style TargetType="ScrollBar">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Width" Value="8" />
            </Style>

            <!-- ListBox styling -->
            <Style x:Key="LogList" TargetType="ListBox">
                <Setter Property="Background" Value="{StaticResource BgElevated2}" />
                <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
                <Setter Property="BorderBrush" Value="{StaticResource StrokeSoft}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
                <Setter Property="FontSize" Value="11" />
                <Setter Property="Padding" Value="8" />
                <Setter Property="ItemContainerStyle">
                    <Setter.Value>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
                            <Setter Property="Padding" Value="2,1" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Expander header restyled -->
            <Style TargetType="Expander">
                <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
                <Setter Property="FontFamily" Value="{StaticResource UiFont}" />
                <Setter Property="FontSize" Value="11" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
