<Window x:Class="SportApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SportApp.ViewModels"
        xmlns:views="clr-namespace:SportApp.Views"
        Title="SPORT · Симулятор соревнований"
        Height="860" Width="1280"
        MinHeight="620" MinWidth="960"
        Background="{StaticResource Bg}"
        FontFamily="{StaticResource UiFont}"
        WindowStartupLocation="CenterScreen"
        TextOptions.TextFormattingMode="Ideal"
        UseLayoutRounding="True">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:CompetitionViewModel}">
            <views:CompetitionView />
        </DataTemplate>
    </Window.Resources>

    <DockPanel>

        <!-- TOP BAR -->
        <Border DockPanel.Dock="Top" Background="{StaticResource BgElevated}" BorderBrush="{StaticResource Stroke}" BorderThickness="0,0,0,1">
            <Grid Margin="28,18,28,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Brand -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="38" Height="38" CornerRadius="10" Background="{StaticResource Accent}" VerticalAlignment="Center">
                        <TextBlock Text="S" FontSize="22" FontWeight="Black" Foreground="#0B0E12"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="SPORT SIMULATOR" FontSize="18" FontWeight="Bold" Foreground="{StaticResource Text}" />
                        <TextBlock Text="модель спортивных соревнований · WPF / MVVM"
                                   FontSize="11" Foreground="{StaticResource TextMuted}" Margin="0,1,0,0" />
                    </StackPanel>
                </StackPanel>

                <!-- Stats -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">

                    <Border Background="{StaticResource BgElevated2}" CornerRadius="8" Padding="18,8" Margin="6,0"
                            BorderBrush="{StaticResource Stroke}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="МОДЕЛЕЙ" Style="{StaticResource Label}" />
                            <TextBlock Text="{Binding CompetitionCount}" Style="{StaticResource Stat}" />
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource BgElevated2}" CornerRadius="8" Padding="18,8" Margin="6,0"
                            BorderBrush="{StaticResource Stroke}" BorderThickness="1">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="7" Height="7" Fill="{StaticResource Danger}" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock Text="В ЭФИРЕ" Style="{StaticResource Label}" />
                            </StackPanel>
                            <TextBlock Text="{Binding RunningCount}" Style="{StaticResource Stat}" Foreground="{StaticResource Accent}" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Actions -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="▶  СТАРТ ВСЕХ" Style="{StaticResource GhostButton}"
                            Command="{Binding StartAllCommand}" Margin="0,0,8,0" />
                    <Button Content="✕  ОТМЕНИТЬ ВСЕ" Style="{StaticResource GhostButton}"
                            Command="{Binding StopAllCommand}" Margin="0,0,8,0" />
                    <Button Content="＋  НОВОЕ СОРЕВНОВАНИЕ" Style="{StaticResource PrimaryButton}"
                            Command="{Binding AddCompetitionCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- EMPTY STATE -->
        <Border DockPanel.Dock="Bottom"
                Visibility="{Binding HasCompetitions, Converter={StaticResource BoolToVisInv}}"
                Padding="28">
            <Border Background="{StaticResource BgElevated}" BorderBrush="{StaticResource Stroke}" BorderThickness="1"
                    CornerRadius="14" Padding="40">
                <StackPanel HorizontalAlignment="Center">
                    <Border Width="64" Height="64" CornerRadius="32" Background="{StaticResource BgElevated2}"
                            BorderBrush="{StaticResource Stroke}" BorderThickness="1">
                        <TextBlock Text="🏟" FontSize="30" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="Арена пуста" Style="{StaticResource H1}" HorizontalAlignment="Center" Margin="0,18,0,6" />
                    <TextBlock Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" TextAlignment="Center"
                               MaxWidth="440" TextWrapping="Wrap"
                               Text="Добавьте соревнование — случайный состав спортсменов выйдет на дорожку. Следите за забегом, травмами и наградами в реальном времени." />
                    <Button Content="＋  ДОБАВИТЬ ПЕРВОЕ СОРЕВНОВАНИЕ" Style="{StaticResource PrimaryButton}"
                            Command="{Binding AddCompetitionCommand}" Margin="0,18,0,0" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>
        </Border>

        <!-- COMPETITIONS -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                      Padding="24,20,24,24">
            <ItemsControl ItemsSource="{Binding Competitions}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </ScrollViewer>

    </DockPanel>
</Window>
