<UserControl x:Class="SportApp.Views.CompetitionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SportApp.ViewModels">

    <Border Style="{StaticResource Card}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Grid Grid.Row="0" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Title block -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Status pill -->
                    <Border CornerRadius="4" Padding="7,3" VerticalAlignment="Center"
                            Background="{Binding StatusColor, Converter={StaticResource StringToBrush}}">
                        <TextBlock Text="{Binding StatusBadge}" FontSize="10" FontWeight="Bold" Foreground="#0B0E12" />
                    </Border>

                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Title}" Style="{StaticResource H2}" />
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <TextBlock Text="{Binding DoctorName}" Foreground="{StaticResource TextMuted}" FontSize="11" />
                            <TextBlock Text="  ·  " Foreground="{StaticResource TextDim}" FontSize="11" />
                            <TextBlock Text="{Binding TrackLength, StringFormat={}{0} м}" Foreground="{StaticResource TextMuted}" FontSize="11" />
                            <TextBlock Text="  ·  " Foreground="{StaticResource TextDim}" FontSize="11" />
                            <TextBlock Text="{Binding AthleteCount, StringFormat={}участников: {0}}" Foreground="{StaticResource TextMuted}" FontSize="11" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Winner callout -->
                <Border Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding HasWinner, Converter={StaticResource BoolToVis}}"
                        Background="#1F2A10" BorderBrush="{StaticResource Accent}" BorderThickness="1"
                        CornerRadius="6" Padding="12,6">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🏆" FontSize="14" VerticalAlignment="Center" />
                        <TextBlock Text="Победитель:" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="8,0,6,0" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding WinnerName}" Foreground="{StaticResource Accent}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- Buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="▶  СТАРТ" Style="{StaticResource PrimaryButton}"
                            Command="{Binding StartCommand}" Margin="0,0,6,0" />
                    <Button Content="✕  ОТМЕНА" Style="{StaticResource GhostButton}"
                            Command="{Binding StopCommand}" Margin="0,0,6,0" />
                    <Button Content="✕" Style="{StaticResource DangerButton}"
                            ToolTip="Удалить соревнование"
                            Command="{Binding DataContext.RemoveCompetitionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding}" />
                </StackPanel>
            </Grid>

            <!-- TRACK -->
            <Border Grid.Row="1" Background="{StaticResource BgElevated2}" BorderBrush="{StaticResource StrokeSoft}" BorderThickness="1"
                    CornerRadius="10" ClipToBounds="True">
                <Grid Height="{Binding CanvasHeight}" HorizontalAlignment="Left" Width="860">

                    <!-- Lane stripes (alternating) via ItemsControl on lanes -->
                    <ItemsControl ItemsSource="{Binding Athletes}" IsHitTestVisible="False"
                                  HorizontalAlignment="Left" Width="860">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas Height="{Binding CanvasHeight}" Width="860" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Top" Value="{Binding TopOffset}" />
                                <Setter Property="Canvas.Left" Value="0" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Width="860" Height="{Binding LaneHeight}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="68" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <!-- Lane label -->
                                    <Border Grid.Column="0" Background="#141821" BorderBrush="{StaticResource StrokeSoft}"
                                            BorderThickness="0,0,1,0">
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding LaneNumber, StringFormat=LANE  {0}}" FontSize="10"
                                                       Foreground="{StaticResource TextDim}" FontWeight="Bold" />
                                            <TextBlock Text="{Binding ProgressPercent, StringFormat={}{0:F0}%}" FontSize="12"
                                                       Foreground="{StaticResource Text}" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,1,0,0" />
                                        </StackPanel>
                                    </Border>
                                    <!-- Lane track (dashed line) -->
                                    <Grid Grid.Column="1">
                                        <Line X1="4" Y1="23" X2="760" Y2="23"
                                              Stroke="#2A303B" StrokeThickness="1" StrokeDashArray="4 6" />
                                    </Grid>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Finish line overlay -->
                    <Canvas IsHitTestVisible="False" HorizontalAlignment="Left" Width="860">
                        <!-- checkered finish column at x=68+720=788 (canvas width 860, track width 720 after lane label) -->
                        <Rectangle Canvas.Left="786" Canvas.Top="0" Width="2"
                                   Height="{Binding CanvasHeight}" Fill="{StaticResource Danger}" />
                        <Border Canvas.Left="790" Canvas.Top="6"
                                Background="{StaticResource Danger}" CornerRadius="3" Padding="5,2">
                            <TextBlock Text="FINISH" FontSize="9" FontWeight="Bold" Foreground="#0B0E12" />
                        </Border>
                        <!-- Start line -->
                        <Rectangle Canvas.Left="68" Canvas.Top="0" Width="2"
                                   Height="{Binding CanvasHeight}" Fill="{StaticResource Accent}" />
                    </Canvas>

                    <!-- Athletes (runners) on top -->
                    <ItemsControl ItemsSource="{Binding Athletes}"
                                  HorizontalAlignment="Left" Width="860">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas Height="{Binding CanvasHeight}" Width="860" Background="Transparent" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Top" Value="{Binding TopOffset}" />
                                <Setter Property="Canvas.Left" Value="{Binding LeftOffset}" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="72,0,0,0" Width="400">
                                    <!-- Runner chip -->
                                    <Border Background="#0F1319" BorderBrush="{Binding ChipColor, Converter={StaticResource StringToBrush}}"
                                            BorderThickness="1.5" CornerRadius="22" Padding="4,3" HorizontalAlignment="Left"
                                            VerticalAlignment="Center" Margin="0,8,0,0">
                                        <StackPanel Orientation="Horizontal">
                                            <!-- Avatar disk -->
                                            <Border Width="28" Height="28" CornerRadius="14"
                                                    Background="{Binding ChipColor, Converter={StaticResource StringToBrush}}">
                                                <TextBlock Text="{Binding LaneNumber}" FontWeight="Black" FontSize="13"
                                                           Foreground="#0B0E12"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>

                                            <StackPanel Margin="8,0,12,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontSize="11" FontWeight="Bold"
                                                           Foreground="{StaticResource Text}" />
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding StateText}" FontSize="9" FontWeight="Bold"
                                                               Foreground="{Binding StateColor, Converter={StaticResource StringToBrush}}" />
                                                    <TextBlock Text="·" Foreground="{StaticResource TextDim}" FontSize="9" Margin="5,0" />
                                                    <TextBlock Text="{Binding SpeedDisplay, StringFormat={}{0:F1} м/с}" FontSize="9"
                                                               Foreground="{StaticResource TextMuted}" />
                                                </StackPanel>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- Injured marker overlay -->
                                    <Border Visibility="{Binding IsInjured, Converter={StaticResource BoolToVis}}"
                                            Width="14" Height="14" CornerRadius="7" Background="{StaticResource Danger}"
                                            HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-3,2,0,0">
                                        <TextBlock Text="!" FontSize="9" FontWeight="Black" Foreground="#0B0E12"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>

                                    <!-- Healing marker -->
                                    <Border Visibility="{Binding IsHealing, Converter={StaticResource BoolToVis}}"
                                            Width="14" Height="14" CornerRadius="7" Background="{StaticResource Warn}"
                                            HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-3,2,0,0">
                                        <TextBlock Text="+" FontSize="10" FontWeight="Black" Foreground="#0B0E12"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>

                                    <!-- Gold medal on finisher -->
                                    <TextBlock Text="🏆" FontSize="16"
                                               Visibility="{Binding IsFinished, Converter={StaticResource BoolToVis}}"
                                               HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-6,-4,0,0" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <!-- ROSTER STRIP -->
            <ItemsControl Grid.Row="2" ItemsSource="{Binding Athletes}" Margin="0,12,0,0">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource BgElevated2}" BorderBrush="{StaticResource StrokeSoft}"
                                BorderThickness="1" CornerRadius="6" Padding="8,5" Margin="0,0,6,6">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                                         Fill="{Binding ChipColor, Converter={StaticResource StringToBrush}}" />
                                <TextBlock Text="{Binding Name}" Foreground="{StaticResource Text}" FontSize="11"
                                           FontWeight="SemiBold" Margin="8,0,10,0" />
                                <TextBlock Text="{Binding BaseSpeed, StringFormat='v₀={0:F1}'}" FontSize="10"
                                           Foreground="{StaticResource TextMuted}" Margin="0,0,8,0" />
                                <TextBlock Text="{Binding InjuryProbabilityPercent, StringFormat='риск {0:F1}%'}"
                                           FontSize="10" Foreground="{StaticResource TextDim}" />
                                <Border Background="#0F1F08" BorderBrush="{StaticResource Accent}" BorderThickness="1"
                                        CornerRadius="4" Padding="5,1" Margin="8,0,0,0">
                                    <TextBlock Text="{Binding OddsDisplay}" FontSize="10" FontWeight="Bold"
                                               Foreground="{StaticResource Accent}" />
                                </Border>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- FOOTER: LOG + AWARD -->
            <Grid Grid.Row="3" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Event log -->
                <Expander Grid.Column="0" IsExpanded="True" Header="ЖУРНАЛ СОБЫТИЙ">
                    <Border Background="{StaticResource BgElevated2}" BorderBrush="{StaticResource StrokeSoft}"
                            BorderThickness="1" CornerRadius="6" Margin="0,6,0,0">
                        <ListBox ItemsSource="{Binding Log}" Style="{StaticResource LogList}" Height="120"
                                 BorderThickness="0" Background="Transparent" />
                    </Border>
                </Expander>

                <!-- Award banner -->
                <Border Grid.Column="1"
                        Visibility="{Binding ShowAward, Converter={StaticResource BoolToVis}}"
                        Background="#1F2A10" BorderBrush="{StaticResource Accent}" BorderThickness="1"
                        CornerRadius="10" Padding="14,10" Margin="12,8,0,0" MaxWidth="360" VerticalAlignment="Top">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🏅" FontSize="22" VerticalAlignment="Center" />
                            <StackPanel Margin="10,0,0,0">
                                <TextBlock Text="ЦЕРЕМОНИЯ НАГРАЖДЕНИЯ" FontSize="9" FontWeight="Bold"
                                           Foreground="{StaticResource Accent}" />
                                <TextBlock Text="{Binding LastAwardTitle}" FontWeight="Bold" FontSize="13"
                                           Foreground="{StaticResource Text}" TextWrapping="Wrap" MaxWidth="280" />
                            </StackPanel>
                        </StackPanel>
                        <TextBlock Text="{Binding LastAwardDescription}" FontSize="10"
                                   Foreground="{StaticResource TextMuted}" Margin="0,8,0,0"
                                   TextWrapping="Wrap" FontFamily="{StaticResource MonoFont}" />
                        <Button Content="Закрыть" Style="{StaticResource GhostButton}"
                                Command="{Binding DismissAwardCommand}"
                                HorizontalAlignment="Right" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
            </Grid>

        </Grid>
    </Border>
</UserControl>
